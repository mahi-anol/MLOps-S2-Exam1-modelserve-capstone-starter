# ============================================================================
# ModelServe — Environment Variables
# ============================================================================
# Copy this file to .env and fill in actual values.
# NEVER commit .env to git — only .env.example.
# ============================================================================
#
# For LOCAL development (docker-compose.yml at the repo root), the defaults
# below are fine — services reach each other on the Docker network.
#
# For CLOUD deployment (the two bootstrap scripts), most of these values are
# wired automatically by Pulumi outputs + the EC2 user-data scripts.
# ============================================================================

# --- MLflow ---
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_MODEL_NAME=fraud-detection-model

# --- Postgres (MLflow backend store) ---
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow_password
POSTGRES_DB=mlflow_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis (Feast online store) ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- AWS (used by the MLflow container so it can read/write S3 in cloud mode) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1

# --- S3 (MLflow artifact store, created by Pulumi in cloud mode) ---
S3_BUCKET_NAME=

# --- Docker Hub (target for the CI-built FastAPI image) ---
DOCKER_HUB_USER=mahianol
DOCKER_IMAGE=mahianol/modelserve-api

# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info

# --- Feast ---
FEAST_REPO_PATH=/app/feast_repo

# --- Deployment override (set on the monitoring EC2 host) ---
# API_IMAGE=mahianol/modelserve-api:latest

